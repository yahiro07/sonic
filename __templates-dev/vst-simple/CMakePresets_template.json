{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "SMTG_RUN_VST_VALIDATOR": "OFF",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "ninja",
      "inherits": "base"
    }
  ],
  "buildPresets": [
    {
      "name": "base",
      "hidden": true,
      "targets": []
    },
    {
      "name": "ninja-debug",
      "configurePreset": "ninja",
      "configuration": "Debug",
      "inherits": "base"
    },
    {
      "name": "ninja-release",
      "configurePreset": "ninja",
      "configuration": "Release",
      "inherits": "base"
    }
  ]
}
