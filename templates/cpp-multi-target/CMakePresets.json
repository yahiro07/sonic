{
  "version": 8,
  "configurePresets": [
    {
      "name": "ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "xcode",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-xcode"
    }
  ],
  "buildPresets": [
    {
      "name": "ninja-debug",
      "configurePreset": "ninja",
      "configuration": "Debug"
    },
    {
      "name": "xcode-debug",
      "configurePreset": "xcode",
      "configuration": "Debug"
    }
  ]
}
