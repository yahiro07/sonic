{
  "version": 8,
  "configurePresets": [
    {
      "name": "ninja",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build"
    },
    {
      "name": "xcode",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build-xcode"
    },
    {
      "name": "ninja-template-dev",
      "inherits": [
        "ninja"
      ],
      "cacheVariables": {
        "SMTG_RUN_VST_VALIDATOR": "OFF",
        "SONIC_USE_LOCAL_SDK": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "ninja-debug",
      "configurePreset": "ninja",
      "configuration": "Debug"
    },
    {
      "name": "xcode-debug",
      "configurePreset": "xcode",
      "configuration": "Debug"
    }
  ]
}